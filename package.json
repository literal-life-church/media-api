{
	"name": "media-api",
	"description": "General-purpose API layer for exposing public information for our live streams and archived sermons",
	"version": "0.0.1",
	"private": true,
	"scripts": {
        "dev": "run/dev.sh",

        "db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:reset": "run/reset-local-db.sh && drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",

		"deploy:secrets": "run/deploy-secrets.sh",

		"dev:generate-signature": "doppler run -- npx tsx run/generate-signature.ts",
		"dev:types": "run/dev-types.sh"
	},
	"dependencies": {
		"chanfana": "3.0.0",
		"drizzle-orm": "1.0.0-beta.17-67b1795",
		"hono": "4.12.7",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"@types/node": "25.4.0",
		"@types/service-worker-mock": "2.0.4",
		"better-sqlite3": "12.6.2",
		"drizzle-kit": "1.0.0-beta.17-67b1795",
		"wrangler": "4.72.0"
	}
}
