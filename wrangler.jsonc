{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "media-api",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-12",

	"observability": {
		"enabled": true
	},

	"compatibility_flags": [
		"nodejs_compat"
	],

	"assets": {
        "directory": "./assets/",
        "binding": "ASSETS"
     },

	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "media-api",
			"database_id": "<CLOUDFLARE_D1_DATABASE_ID>",
			"migrations_dir": "drizzle"
		}
	]
}
